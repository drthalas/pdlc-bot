TELEGRAM_BOT_TOKEN=replace-me
# Comma-separated Telegram numeric user IDs. Leave empty to allow all users.
TELEGRAM_ALLOWED_USER_IDS=

PROJECTS_CONFIG_PATH=config/projects.yaml
TASKS_DIR=tasks
DATABASE_PATH=tasks/pdlc_bot.sqlite3

PDLC_ENABLE_CODEX_RUNNER=false
# Supported modes: disabled, prepare, branch_prepare, git_check.
# Prepare modes write manual-run artifacts only.
PDLC_CODEX_RUNNER_MODE=disabled
PDLC_CODEX_BIN=/opt/homebrew/bin/codex
